// ============================================================================
// ORGANIZATION
// ============================================================================

model Organization {
  id                 String           @id @default(uuid())
  nameId             String
  name               Vault            @relation("OrganizationName", fields: [nameId], references: [id], onDelete: Cascade)
  type               OrganizationType
  contactPhoneId     String?
  contactPhone       Vault?           @relation("OrganizationPhone", fields: [contactPhoneId], references: [id], onDelete: SetNull)
  contactEmailId     String?
  contactEmail       Vault?           @relation("OrganizationEmail", fields: [contactEmailId], references: [id], onDelete: SetNull)
  licenseNumberId    String?
  licenseNumber      Vault?           @relation("OrganizationLicense", fields: [licenseNumberId], references: [id], onDelete: SetNull)
  registrationNumber String?          @unique
  isVerified         Boolean          @default(false)
  verificationDate   DateTime?
  locationId         String?          @unique
  location           Location?        @relation("OrganizationLocation")
  adminId            Int
  admin              User             @relation("OrganizationAdmin", fields: [adminId], references: [id], onDelete: Restrict)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  bloodInventories     BloodInventory[]      @relation("OrganizationInventory")
  donationAppointments DonationAppointment[] @relation("OrganizationAppointment")
  bloodRequests        BloodRequest[]        @relation("OrganizationRequest")
  donations            Donation[]            @relation("DonationOrganization")

  @@index([type, isVerified])
}

enum OrganizationType {
  HOSPITAL
  BLOOD_BANK
  CLINIC
  NGO
}
