// ============================================================================
// DonationAppointment Model - Scheduled Blood Donation Events
// ============================================================================
// Represents scheduled appointments for blood donation at specific dates/times.
// Tracks appointment status, completion, and can be linked to actual donations.
// Supports reminders and cancellation management.
// ============================================================================

model DonationAppointment {
  /// Unique identifier for appointment (UUID)
  id String @id @default(uuid())

  // --- Appointment Participants ---
  /// Reference to donor scheduled for this appointment
  donorId Int
  donor   User @relation("UserAppointments", fields: [donorId], references: [id], onDelete: Cascade)

  /// Reference to organization where donation will occur
  organizationId String
  organization   Organization @relation("OrganizationAppointment", fields: [organizationId], references: [id], onDelete: Cascade)

  // --- Appointment Scheduling ---
  /// Date and time of the scheduled appointment
  appointmentTime DateTime

  /// Current status of appointment (SCHEDULED, CONFIRMED, COMPLETED, CANCELLED, NO_SHOW, RESCHEDULED)
  status AppointmentStatus @default(SCHEDULED)

  // --- Appointment Notes ---
  /// Reference to encrypted appointment notes/instructions for donor
  notesId String?
  notes   Vault?  @relation("AppointmentNotes", fields: [notesId], references: [id], onDelete: SetNull)

  /// Date and time the appointment was completed
  completedAt DateTime?

  // --- Donation Link ---
  /// Optional reference to donation record (if appointment resulted in donation)
  donationId String?   @unique
  donation   Donation? @relation("AppointmentDonation", fields: [donationId], references: [id], onDelete: SetNull)

  // --- Cancellation ---
  /// Reference to encrypted cancellation reason (if applicable)
  cancellationReasonId String?
  cancellationReason   Vault?  @relation("AppointmentCancellationReason", fields: [cancellationReasonId], references: [id], onDelete: SetNull)

  /// Date and time appointment reminder was sent to donor
  reminderSentAt DateTime?

  // --- System Metadata ---
  /// When appointment was created/booked
  createdAt DateTime @default(now())
  /// Last modification timestamp
  updatedAt DateTime @updatedAt

  // --- Database Indexes ---
  /// Index for querying donor's upcoming appointments
  @@index([donorId, appointmentTime])
  /// Index for organization's appointment schedule
  @@index([organizationId, appointmentTime])
  /// Index for filtering by status and date (e.g., upcoming appointments)
  @@index([status, appointmentTime])
}

// ============================================================================
// AppointmentStatus Enum - Donation Appointment Status
// ============================================================================
/// Status of a scheduled blood donation appointment
/// SCHEDULED: Appointment created but not yet confirmed
/// CONFIRMED: Donor has confirmed attendance
/// COMPLETED: Donation occurred, appointment fulfilled
/// CANCELLED: Appointment cancelled by donor or organization
/// NO_SHOW: Donor did not appear at scheduled time
/// RESCHEDULED: Original appointment moved to different date/time
enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}
