// ============================================================================
// AUTH
// ============================================================================

model Auth {
  id                 String              @id @default(uuid())
  passwordHash       String?
  passwordHashMethod PasswordHashMethod? @default(BCRYPT)
  otpHash            String?
  otpExp             DateTime?
  canResetPassword   Boolean?            @default(false)
  loginAttempts      Int                 @default(0)
  twoFactorEnabled   Boolean?            @default(false)
  twoFactorSecretId  String?
  twoFactorSecret    Vault?              @relation("AuthTwoFactorSecret", fields: [twoFactorSecretId], references: [id], onDelete: SetNull)
  isEmailVerified    Boolean?            @default(false)
  isPhoneVerified    Boolean?            @default(false)
  isActive           Boolean             @default(true)
  unlockAt           DateTime?
  userId             Int                 @unique
  user               User                @relation("AuthUser", fields: [userId], references: [id], onDelete: Cascade)
}

enum PasswordHashMethod {
  BCRYPT
  ARGON2
  SCRYPT
  PBKDF2
}
