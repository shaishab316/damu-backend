// ============================================================================
// BloodInventory Model - Blood Bank Inventory Management
// ============================================================================
// Tracks blood stock levels by blood group for each organization.
// Monitors usage, expiration, and low-stock alerts.
// One record per organization per blood group combination.
// ============================================================================

model BloodInventory {
  /// Unique identifier for inventory record (UUID)
  id String @id @default(uuid())

  // --- Organization Reference ---
  /// Reference to organization managing this blood inventory
  organizationId String
  organization   Organization @relation("OrganizationInventory", fields: [organizationId], references: [id], onDelete: Cascade)

  // --- Blood Group ---
  /// Reference to encrypted blood group (O+, O-, B+, B-, A+, A-, AB+, AB-)
  bloodGroupId String
  bloodGroup   Vault  @relation("InventoryBloodGroup", fields: [bloodGroupId], references: [id])

  // --- Stock Levels (in units) ---
  /// Number of blood units currently available for transfusion
  unitsAvailable Int @default(0)
  /// Number of blood units that have been used (historical tracking)
  unitsUsed      Int @default(0)
  /// Number of blood units that have expired and were removed
  unitsExpired   Int @default(0)

  // --- Activity Tracking ---
  /// Last date blood units of this type were added to inventory
  lastRestockedAt DateTime?
  /// Last date blood units of this type were used for transfusion
  lastUsedAt      DateTime?

  // --- Low Stock Management ---
  /// Minimum number of units before generating low-stock alert
  minimumThreshold Int     @default(5)
  /// Whether current inventory is below minimum threshold
  isLowStock       Boolean @default(false)

  // --- System Metadata ---
  /// Last modification timestamp (updated whenever inventory changes)
  updatedAt DateTime @updatedAt
  /// When this inventory record was created
  createdAt DateTime @default(now())

  // --- Database Constraints ---
  /// Unique constraint ensures one record per organization/blood-group pair
  @@unique([organizationId, bloodGroupId])
  /// Index for efficient low-stock queries
  @@index([organizationId, isLowStock])
}
