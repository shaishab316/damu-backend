// ============================================================================
// DEVICE SESSION - Multi-device support
// ============================================================================

model DeviceSession {
  id               String       @id @default(uuid())
  userId           Int
  user             User         @relation("UserDeviceSessions", fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String       @unique
  deviceNameId     String?
  deviceName       Vault?       @relation("DeviceSessionDeviceInfo", fields: [deviceNameId], references: [id], onDelete: SetNull)
  deviceType       DeviceType   @default(WEB)
  ipAddress        String?
  userAgent        String?
  lastActiveAt     DateTime     @default(now())
  expiresAt        DateTime
  createdAt        DateTime     @default(now())
  pushToken        String?
  pushProvider     PushProvider @default(FCM)

  @@index([userId])
  @@index([expiresAt])
}

enum DeviceType {
  WEB
  MOBILE
  TABLET
  DESKTOP
  WINDOWS
  MACOS
  LINUX
}

enum PushProvider {
  FCM
  ONESIGNAL
  APNS
}
