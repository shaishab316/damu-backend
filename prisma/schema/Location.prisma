// ============================================================================
// LOCATION
// ============================================================================

model Location {
  id            String  @id @default(uuid())
  latitude      Float?
  longitude     Float?
  address       String?
  country       String?
  state         String?
  city          String?
  h3IndexLevel5 String?
  h3IndexLevel6 String?
  h3IndexLevel7 String?
  h3IndexLevel8 String?

  updatedAt DateTime @updatedAt

  userId         Int?           @unique
  user           User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?        @unique
  organization   Organization?  @relation("OrganizationLocation", fields: [organizationId], references: [id], onDelete: SetNull)
  bloodRequests  BloodRequest[] @relation("RequestLocation")

  @@index([h3IndexLevel5])
  @@index([h3IndexLevel6])
  @@index([h3IndexLevel7])
  @@index([h3IndexLevel8])
  @@index([country, state, city])
  @@index([latitude, longitude])
  @@map("locations")
}
